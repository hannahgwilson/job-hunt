# Copy to .env.local and fill in. These are the PUBLISHABLE Supabase values —
# the anon key is safe in a client bundle because Row Level Security scopes every
# query to the logged-in user. NEVER put the service_role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY
